		"playwright": "^1.57.0",
		"svelte": "^5.41.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.1.14",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	},
	"dependencies": {
		"@hackclub/icons": "^0.0.15",
		"airtable": "^0.12.2",
		"dotenv": "^17.2.3",
